using UnityEngine;

public class Ejercicio12 : MonoBehaviour
{
    public int[] daños = { 10, 15, 20, 5, 30 };
    int j = 0;
    int dañoTotal = 0;
    void Start()
    {
        while (j < daños.Length)
        {
            dañoTotal += daños[j];
            j++;
        }

        Debug.Log("Daño total recibido: " + dañoTotal);
    }
    void Update()
    {
        
    }
}
