using System.Collections.Generic;
using UnityEngine;

public class Ejercicio12 : MonoBehaviour
{
    public int[] daños = { 10, 15, 20, 5, 30 };
    void Start()
    {
        {
            int totalDamage = CalculateTotalDamage(daños);
            Debug.Log("Daño total recibido: " + totalDamage);
        }

        int CalculateTotalDamage(int[] damageArray)
        {
            int total = 0;

            foreach (int damage in damageArray)
            {
                total += damage;
            }

            return total;
        }
    }
    void Update()
    {
        
    }
}
